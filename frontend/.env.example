# Copy to .env.local and fill in values
# For local development, defaults (localhost) are used automatically

# WebSocket URL of the Kaizen OS backend
VITE_WS_URL=ws://localhost:8000/ws

# REST API base URL
VITE_API_URL=http://localhost:8000

# For HuggingFace Space deployment:
# VITE_WS_URL=wss://your-space-name.hf.space/ws
# VITE_API_URL=https://your-space-name.hf.space
